# pdfNest — environment variables
# All integrations are independently env-gated: absent key = feature silently disabled.
# Copy this file to .env.local and fill in only what you need.
# Empty .env = fully functional app (all tools work; integrations off).

# ── Site ──
# Production domain — used for canonical URLs, sitemap, and OG images.
# Leave blank for localhost dev. Set to your domain on Vercel.
# NEXT_PUBLIC_SITE_URL=https://pdfnest.app

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# ── Analytics (optional) ──
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Error tracking (optional) ──
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ── Google Search Console (optional) ──
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxx

# ── AdSense (optional — both must be set to enable ad slots) ──
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_ENABLED=true

# ── Formspree (contact form — mailto fallback used when absent) ──
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx
